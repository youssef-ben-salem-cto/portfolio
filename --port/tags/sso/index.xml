    <item>
      <title>Bravvo: AI-Augmented Enterprise Platform</title>
      <link>http://localhost:1313/projects/bravvo/</link>
      <pubDate>Sun, 01 Jan 2023 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/projects/bravvo/</guid>
      <description>&lt;div class=&#34;mb-12 flex flex-col md:flex-row items-center md:items-start gap-8&#34;&gt;&#xA;&lt;div class=&#34;shrink-0&#34;&gt;&#xA;&lt;img src=&#34;images/bravvo-logo.svg&#34; alt=&#34;Bravvo&#34; class=&#34;w-32 h-32 object-contain bg-slate-900 rounded-3xl shadow-md border border-border-primary dark:border-border-primary p-2&#34;&gt;&#xA;&lt;/div&gt;&#xA;&lt;div class=&#34;text-lg text-text-secondary dark:text-text-secondary leading-relaxed&#34;&gt;&#xA;&lt;p class=&#34;mb-4&#34;&gt;&lt;strong class=&#34;text-text-primary dark:text-text-primary font-bold&#34;&gt;Driving ESG Impact Through Employee Engagement:&lt;/strong&gt; Bravvo V2 is the ultimate employee engagement and sustainability platform. It transforms corporate ESG (Environmental, Social, and Governance) goals into actionable, daily habits. By leveraging gamification and intelligent challenges, Bravvo empowers employees to act, learn, and contribute to real-world impact in just 10 minutes a day.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Beekeeper Tech</title>
      <link>http://localhost:1313/projects/beekeeper/</link>
